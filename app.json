{
  "expo": {
    "name": "Kakasa",
    "slug": "m-sente",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kakasa",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4C2311"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kakasa.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Kakasa uses Face ID to securely unlock your account and authorize transactions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4C2311"
      },
      "package": "com.kakasa.app",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4C2311"
        }
      ],
      "expo-image",
      "expo-local-authentication",
      "expo-status-bar",
      [
        "expo-camera",
        {
          "cameraPermission": "Kakasa uses the camera to capture your National ID and a quick face check for your loan application."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0bf3d476-1291-4762-af19-d266b8f70fe9"
      }
    },
    "owner": "judeotine"
  }
}
